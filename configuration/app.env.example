# JWT configuration
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# CORS configuration (comma-separated list of allowed origins, leave empty to disable)
# Example: CORS_ALLOWED_ORIGINS=https://example.com,https://app.example.com
CORS_ALLOWED_ORIGINS=

# OpenAI configuration (set base_url to use a compatible provider like Ollama, vLLM, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Storage configuration
STORAGE_BASE_PATH=/data/content
