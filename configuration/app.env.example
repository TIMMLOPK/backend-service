# JWT configuration
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# CORS configuration (comma-separated list of allowed origins, leave empty to disable)
# Example: CORS_ALLOWED_ORIGINS=https://example.com,https://app.example.com
CORS_ALLOWED_ORIGINS=

# MiniMax configuration
# MINIMAX_API_KEY=
# MINIMAX_GROUP_ID=

# AWS configuration (optional — uses IAM roles when not set)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
